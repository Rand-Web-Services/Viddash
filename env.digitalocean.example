# Copy this file to .env.production on the Droplet and fill in real values.
# Keep .env.production out of git.

VIDDASH_DOMAIN=app.example.com
VIDDASH_PUBLIC_URL=https://app.example.com
ACME_EMAIL=admin@example.com
VIDDASH_ENV=production
VIDDASH_SECRET_KEY=replace-with-a-long-random-secret

POSTGRES_DB=viddash
POSTGRES_USER=viddash
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql://viddash:replace-with-a-strong-database-password@postgres:5432/viddash

RATELIMIT_STORAGE_URI=redis://redis:6379/0
MAX_UPLOAD_SIZE_MB=100
MAX_UPLOAD_HARD_LIMIT_MB=512

# Google OAuth only. Leave GitHub vars unset if you do not want GitHub SSO.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Transactional email via Resend.
RESEND_API_KEY=
MAIL_FROM=noreply@viddash.app
SUPPORT_EMAIL=support@viddash.app
ADMIN_EMAILS=admin@example.com

# Stripe billing. Prefer a restricted key (rk_live_...) when possible.
STRIPE_RESTRICTED_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=
